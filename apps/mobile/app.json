{
  "expo": {
    "name": "PagoFirme",
    "slug": "pagofirme",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "pagofirme",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#06a574"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "bo.pagofirme.app"
    },
    "android": {
      "package": "bo.pagofirme.app",
      "adaptiveIcon": {
        "backgroundColor": "#06a574"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "http://localhost:3001"
    }
  }
}
