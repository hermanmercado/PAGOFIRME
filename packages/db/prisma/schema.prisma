// PagoFirme — Esquema de base de datos
// Plataforma de cobros QR para Bolivia con jerarquía de equipos.
//
// Modelo de dominio (refleja el frontend en apps/web):
//   Dueño ── posee ──▶ Unidad de negocio ── tiene ──▶ Supervisores (sucursal)
//                                                  └─▶ Vendedores
//   Vendedor ── confirma ──▶ Ticket (cobro confirmado) usando un QrCode.
//
// Convención de dinero: todos los importes se guardan en la unidad menor
// (centavos de BOB) como BigInt para evitar errores de punto flotante.
// 1 Bs = 100. Ej.: Bs 2.000 → 200000.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // La URL viene de la variable de entorno DATABASE_URL (la inyecta Railway en
  // producción). Para Prisma 7 la URL de Migrate/Introspect vive en
  // prisma.config.ts; el cliente la lee en runtime desde process.env.
}

// ─────────────────────────────────────────────────────────────
// Autenticación y usuarios
// ─────────────────────────────────────────────────────────────

enum UserRole {
  VENDEDOR // opera la caja y confirma cobros
  SUPERVISOR // gestiona una sucursal/tienda y su equipo de vendedores
  DUENO // dueño del negocio; administra unidades, supervisores y límites
  ADMIN // superadmin interno de PagoFirme (verificación, soporte)
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  CLOSED
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  phone         String?    @unique
  passwordHash  String
  fullName      String
  role          UserRole   @default(VENDEDOR)
  status        UserStatus @default(ACTIVE)
  emailVerified Boolean    @default(false)
  phoneVerified Boolean    @default(false)

  // 2FA (TOTP)
  twoFactorEnabled Boolean  @default(false)
  twoFactorSecret  String?
  twoFactorBackup  String[] @default([])

  // ── Organización ──────────────────────────────────────────
  // Unidades de negocio que posee (sólo aplica a DUENO).
  ownedUnits BusinessUnit[] @relation("UnitOwner")

  // Unidad a la que pertenece (SUPERVISOR y VENDEDOR).
  businessUnitId String?
  businessUnit   BusinessUnit? @relation("UnitMembers", fields: [businessUnitId], references: [id], onDelete: SetNull)

  // Jerarquía: un VENDEDOR reporta a un SUPERVISOR (auto-relación).
  supervisorId String?
  supervisor   User?   @relation("SupervisorTeam", fields: [supervisorId], references: [id], onDelete: SetNull)
  team         User[]  @relation("SupervisorTeam")

  // Sucursal/tienda a cargo (SUPERVISOR) o donde opera (VENDEDOR).
  branchName String?

  // Límite por cobro propio (NIVEL 2), en centavos. Null = hereda el de la
  // unidad. Nunca debe superar el tope regulatorio del BCB (NIVEL 1), que se
  // valida en código (BCB_MAX), no en la base de datos.
  perTicketLimit BigInt?

  // Código de cobro público y estable: pagofirme.bo/pagar/{payCode}.
  payCode String? @unique

  // ── Relaciones operativas ─────────────────────────────────
  tickets       Ticket[]
  qrCodes       QrCode[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lastLogin DateTime?

  @@index([role])
  @@index([status])
  @@index([businessUnitId])
  @@index([supervisorId])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  family    String // rotación: identifica la cadena de tokens
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([family])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────
// Unidades de negocio
// ─────────────────────────────────────────────────────────────

enum Currency {
  BOB // Boliviano
  USD
}

model BusinessUnit {
  id     String  @id @default(cuid())
  name   String
  active Boolean @default(true)

  // Dueño de la unidad.
  ownerId String
  owner   User   @relation("UnitOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  currency       Currency @default(BOB)
  // Límite por cobro de la unidad (NIVEL 2), en centavos. Null = sólo aplica el
  // tope BCB (NIVEL 1). Debe ser <= BCB_MAX.
  perTicketLimit BigInt?

  // Miembros de la unidad (supervisores y vendedores).
  members User[]   @relation("UnitMembers")
  qrCodes QrCode[]
  tickets Ticket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([active])
  @@map("business_units")
}

// ─────────────────────────────────────────────────────────────
// Códigos QR (por negocio / vendedor)
// ─────────────────────────────────────────────────────────────

enum QrType {
  DAILY // QR diario automático por vendedor (cambia cada día)
  STATIC // monto abierto, reutilizable
  DYNAMIC // monto fijo, un solo uso
}

enum QrStatus {
  ACTIVE
  PAID
  EXPIRED
  CANCELLED
}

model QrCode {
  id   String @id @default(cuid())
  code String @unique // payload/código del QR, ej. "PF-20260618-123456"

  businessUnitId String
  businessUnit   BusinessUnit @relation(fields: [businessUnitId], references: [id], onDelete: Cascade)

  // Vendedor dueño del QR (los QR DAILY son por vendedor).
  vendorId String?
  vendor   User?   @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  type      QrType    @default(DAILY)
  status    QrStatus  @default(ACTIVE)
  currency  Currency  @default(BOB)
  amount    BigInt? // null para QR de monto abierto
  label     String?
  // Fecha de validez (QR diarios) en hora local, formato YYYY-MM-DD.
  validOn   String?
  expiresAt DateTime?

  tickets Ticket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessUnitId, status])
  @@index([vendorId])
  @@map("qr_codes")
}

// ─────────────────────────────────────────────────────────────
// Tickets (cobros confirmados)
// ─────────────────────────────────────────────────────────────

enum TicketStatus {
  CONFIRMED // cobro confirmado
  REFUNDED // reembolsado
  CANCELLED // anulado
}

model Ticket {
  id     String @id @default(cuid())
  // Número correlativo legible por unidad (#T-0001).
  number Int

  businessUnitId String
  businessUnit   BusinessUnit @relation(fields: [businessUnitId], references: [id])

  // Vendedor que confirmó el cobro.
  vendorId String
  vendor   User   @relation(fields: [vendorId], references: [id])

  // QR usado para el cobro (si aplica).
  qrCodeId String?
  qrCode   QrCode? @relation(fields: [qrCodeId], references: [id])

  status   TicketStatus @default(CONFIRMED)
  currency Currency     @default(BOB)
  // Total cobrado, en centavos.
  total    BigInt
  // Detalle de líneas del cobro: [{ id, expr, monto }]. Ver apps/web/.../caja.ts.
  lines    Json         @default("[]")

  payerName String?
  reference String?
  metadata  Json    @default("{}")

  confirmedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([businessUnitId, number])
  @@index([vendorId, confirmedAt])
  @@index([businessUnitId, confirmedAt])
  @@map("tickets")
}

// ─────────────────────────────────────────────────────────────
// Auditoría
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String?
  entityId  String?
  ipAddress String?
  userAgent String?
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
