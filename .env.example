# ─────────────────────────────────────────────────────────────
# PagoFirme — Variables de entorno (copiar a .env)
# ─────────────────────────────────────────────────────────────

# Entorno
NODE_ENV=development

# ── Base de datos (PostgreSQL) ──────────────────────────────
# Railway expone DATABASE_URL automáticamente en producción.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pagofirme?schema=public"
# Conexión directa (sin pooler) para migraciones de Prisma.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/pagofirme?schema=public"

# ── Auth / JWT ──────────────────────────────────────────────
JWT_ACCESS_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
JWT_REFRESH_SECRET="cambia-esto-por-otro-secreto-largo-y-aleatorio"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# ── 2FA ─────────────────────────────────────────────────────
TOTP_ISSUER="PagoFirme"

# ── API ─────────────────────────────────────────────────────
API_PORT=3001
API_HOST="0.0.0.0"
CORS_ORIGIN="http://localhost:3000"

# ── Web (Next.js) ───────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ── Mobile (Expo) ───────────────────────────────────────────
EXPO_PUBLIC_API_URL="http://localhost:3001"
